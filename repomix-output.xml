    <div className="max-w-3xl mx-auto px-4 py-8">
      <h1 className="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Yeni Yazı</h1>
      <PostForm onSubmit={handleSubmit} isLoading={loading} error={error} />
    </div>
  );
}
